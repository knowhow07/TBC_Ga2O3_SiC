# ===== Stage 1: Robust pre-SCF for slab (from atomic density) =====
# Start clean (good initial density)
ISTART = 0
ICHARG = 2
# INIWAV = 0

# Electronic minimization (stable for slabs)
ALGO   = Normal
LREAL  = .FALSE.
ENCUT  = 500
PREC   = Accurate
EDIFF  = 1E-5
NELM   = 500

# Slab-friendly mixing (tames charge sloshing)
AMIX    = 0.2
BMIX    = 0.0001
LMAXMIX = 4
MAXMIX  = 80

# Smearing (insulating/semiconducting slabs)
# ISMEAR = -5         # tetrahedron; if needed, use: ISMEAR=0; SIGMA=0.05
# SIGMA  = 0.05

# Dipole correction (vacuum along z)
LDIPOL = .TRUE.
IDIPOL = 3
# IMPORTANT: set DIPOL's z to the slab's fractional center (update the 3rd number):
DIPOL  = 0.5 0.5 0.5   # <-- replace 0.38 by your slab center (fractional z)

# Outputs you likely want
LAECHG = .TRUE.
LCHARG = .TRUE.
LWAVE  = .TRUE.
LVHAR  = .TRUE.
LVTOT  = .TRUE.
LELF   = .TRUE.

# Keep the SAME KPOINTS as your interface run.
# For charge-difference work, also pin the FFT grid to match the interface:
# NGX = <from interface OUTCAR>
# NGY = <from interface OUTCAR>
# NGZ = <from interface OUTCAR>
# (and NGXF/NGYF/NGZF if you used them)
